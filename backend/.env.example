# Copy to .env and fill in — never commit the real .env
PORT=4000
MONGO_URI=mongodb://localhost:27017/shuaa
INFERENCE_SERVICE_URL=http://localhost:8001
# Comma-separated list of allowed frontend origins (no wildcard)
ALLOWED_ORIGINS=http://localhost:3000
# Max POST /api/diagnose requests per IP per minute
DIAGNOSE_RATE_LIMIT=20
